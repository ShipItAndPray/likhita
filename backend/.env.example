# Likhita Foundation backend — environment variables
# Copy to .env.local and fill in real values for local dev.
# All values below are placeholders.

# Database (Neon Postgres)
DATABASE_URL=

# Clerk (Sign in with Apple primary)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe (USD)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Razorpay (INR)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Apple StoreKit 2 server validation
APPLE_BUNDLE_ID_RAMA=org.likhita.rama
APPLE_BUNDLE_ID_RAM=org.likhita.ram
APPLE_SHARED_SECRET=
APPLE_KEY_ID=
APPLE_ISSUER_ID=
APPLE_PRIVATE_KEY_BASE64=

# Inngest (background queue)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Sentry (monitoring)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# PostHog (analytics)
POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Vercel Blob (PDFs, photos, receipts)
BLOB_READ_WRITE_TOKEN=

# APNs (push notifications)
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_KEY_BASE64=

# Runtime mode
LIKHITA_RUNTIME=development
