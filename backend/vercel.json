{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "functions": {
    "app/api/v1/kotis/[id]/entries/route.ts": {
      "maxDuration": 15
    },
    "app/api/v1/payments/stripe/webhook/route.ts": {
      "maxDuration": 30
    },
    "app/api/v1/payments/razorpay/webhook/route.ts": {
      "maxDuration": 30
    }
  }
}
